              #CryptoBlob
              #
            ENDARRAY
        ENDPROPERTIES
        
      FIELD #InstanceName
        Id 50003
        STRING
        PROPERTIES
          Name                #InstanceName
          Table               #FIN_GroupDataSourcePassword
